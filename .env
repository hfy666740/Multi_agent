# ==================== JWT 认证配置 ====================
# JWT 签名密钥，生产环境必须修改！
# 生成方法: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=

# ==================== 数据库配置 ====================
# PostgreSQL 数据库连接字符串
DATABASE_URL=

# ==================== LLM 配置 ====================
# 通义千问 API Key (从 https://dashscope.aliyun.com 获取)
DASHSCOPE_API_KEY=

# ==================== LangSmith 可观测性配置 ====================
# 启用 LangSmith 追踪（true/false）
# 启用后所有 LangChain 调用会自动上报到 https://smith.langchain.com
LANGCHAIN_TRACING_V2=false

# LangSmith API Key（从 https://smith.langchain.com/settings 获取）
# LANGCHAIN_API_KEY=

# LangSmith 项目名称
LANGCHAIN_PROJECT=ai-customer-service

# LangSmith 自部署端点（仅自部署场景需要设置）
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
